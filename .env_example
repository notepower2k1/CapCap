MS_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
MS_TRANSLATOR_API_KEY=
MS_TRANSLATOR_REGION=
MS_TRANSLATOR_API_VERSION=3.0

# --- AI Translation Providers ---
# Options: gemini, openrouter
AI_POLISHER_PROVIDER=gemini

# --- Google Gemini Settings ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- OpenRouter Settings (Alternative) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# --- Application Paths ---
WORKSPACE_ROOT=.
