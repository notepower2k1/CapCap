MS_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
MS_TRANSLATOR_API_KEY=
MS_TRANSLATOR_REGION=
MS_TRANSLATOR_API_VERSION=3.0

# Optional fallback when local or Gemini translation is unavailable.

# --- Optional Download Links For Portable Setup ---
# These links are used by the Settings popup when users click download buttons.
LOCAL_MODEL_DOWNLOAD_URL=https://huggingface.co/google/gemma-2-2b-it-gguf
GPU_PACK_DOWNLOAD_URL=https://github.com/Purfview/whisper-standalone-win/releases/tag/libs
PIPER_VOICES_DOWNLOAD_URL=https://huggingface.co/rhasspy/piper-voices

# --- AI Translation Provider ---
# Options: local, gemini
AI_POLISHER_PROVIDER=local

# --- Remote API Mode (Optional PC -> Laptop split) ---
CAPCAP_REMOTE_API_URL=http://127.0.0.1:8765
CAPCAP_REMOTE_API_TOKEN=
CAPCAP_REMOTE_API_HOST=0.0.0.0
CAPCAP_REMOTE_API_PORT=8765
CAPCAP_REMOTE_API_TIMEOUT=600

# --- Google Gemini Settings (Optional Cloud Acceleration) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- Local GGUF Translator (Default) ---
LOCAL_TRANSLATOR_MODEL_PATH=models/ai/gemma-4-E4B-it-Q4_K_M.gguf
LOCAL_TRANSLATOR_N_CTX=2048
LOCAL_TRANSLATOR_N_THREADS=8
LOCAL_TRANSLATOR_N_THREADS_BATCH=8
LOCAL_TRANSLATOR_N_BATCH=768
LOCAL_TRANSLATOR_N_UBATCH=384
LOCAL_TRANSLATOR_GPU_LAYERS=0
LOCAL_TRANSLATOR_FLASH_ATTN=false
LOCAL_TRANSLATOR_TEMPERATURE=0.15
LOCAL_TRANSLATOR_MAX_TOKENS=1400
